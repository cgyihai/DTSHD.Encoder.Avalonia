<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="using:System">

    <!-- 导航 -->
    <sys:String x:Key="Lang.Nav.Encode">音频编码</sys:String>
    <sys:String x:Key="Lang.Nav.Stream">DTS-HD StreamTools</sys:String>

    <!-- 通用 -->
    <sys:String x:Key="Lang.Common.Browse">浏览…</sys:String>

    <!-- 编码页 -->
    <sys:String x:Key="Lang.Encode.Title">音频编码</sys:String>
    <sys:String x:Key="Lang.Encode.Subtitle">选择输入，设置参数，写出 .cfg 并提交 DtsJobQueue 引擎编码。</sys:String>
    <sys:String x:Key="Lang.Encode.ResetDefaults">恢复默认</sys:String>
    <sys:String x:Key="Lang.Encode.LoadSettings">加载设置</sys:String>
    <sys:String x:Key="Lang.Encode.SaveSettings">保存设置</sys:String>
    <sys:String x:Key="Lang.Encode.SaveSettingsAs">设置另存为</sys:String>
    <sys:String x:Key="Lang.Encode.SectionInputOutput">输入 / 输出</sys:String>
    <sys:String x:Key="Lang.Encode.SectionEncodeSettings">编码设置</sys:String>
    <sys:String x:Key="Lang.Encode.SectionTimecode">时间码设置 (Timecode)</sys:String>
    <sys:String x:Key="Lang.Encode.SectionBitstream">比特流 (Bitstream / 元数据)</sys:String>
    <sys:String x:Key="Lang.Encode.SectionDownmix">下混 (Downmix)</sys:String>
    <sys:String x:Key="Lang.Encode.Start">开始编码</sys:String>
    <sys:String x:Key="Lang.Encode.Stop">终止编码</sys:String>
    <sys:String x:Key="Lang.Encode.OpenQueue">打开编码队列</sys:String>
    <sys:String x:Key="Lang.Encode.PreviewCfg">预览 .cfg</sys:String>
    <sys:String x:Key="Lang.Encode.PreviewCmd">预览命令</sys:String>
    <sys:String x:Key="Lang.Encode.ViewLog">查看日志</sys:String>

    <!-- StreamTools 页 -->
    <sys:String x:Key="Lang.Stream.Title">DTS-HD StreamTools</sys:String>
    <sys:String x:Key="Lang.Stream.Subtitle">对已编码的 .dtshd/.cpt 码流做信息/校验/拆分/合并/裁剪/加静音/重打时间码/元数据等处理（原生 DTSToolFramewrk 引擎，模块 T）。</sys:String>

    <!-- 设置页 -->
    <sys:String x:Key="Lang.Settings.Title">设置</sys:String>
    <sys:String x:Key="Lang.Settings.Subtitle">配置工具集、许可证、外观与运行偏好。</sys:String>
    <sys:String x:Key="Lang.Settings.Engine">DTS-HD 引擎 (DtsJobQueue)</sys:String>
