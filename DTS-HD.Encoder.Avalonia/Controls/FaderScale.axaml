<UserControl
    x:Class="DTSHD.Encoder.Avalonia.Controls.FaderScale"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Spacing="2" Width="44">
        <TextBlock Text="dB" HorizontalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
        <Grid Height="150">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <!-- 顶部=+12，底部=INF；0dB 行加粗 -->
            <TextBlock Grid.Row="0" Text="+12" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            <TextBlock Grid.Row="1" Text="0"   FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            <TextBlock Grid.Row="2" Text="-12" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            <TextBlock Grid.Row="3" Text="-24" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            <TextBlock Grid.Row="4" Text="-36" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            <TextBlock Grid.Row="5" Text="-48" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Top"/>
            <TextBlock Grid.Row="5" Text="INF" FontSize="11" Opacity="0.7" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>
        </Grid>
    </StackPanel>
</UserControl>
