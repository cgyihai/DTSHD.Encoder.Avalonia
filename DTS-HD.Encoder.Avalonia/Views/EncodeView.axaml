<UserControl
    x:Class="DTSHD.Encoder.Avalonia.Views.EncodeView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="using:DTSHD.Encoder.Avalonia.Controls"
    xmlns:fui="using:AvaloniaFluentUI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:srv="using:DTSHD.Encoder.Avalonia.Services"
    xmlns:vm="using:DTSHD.Encoder.Avalonia.ViewModels"
    mc:Ignorable="d"
    x:Name="Root"
    x:DataType="vm:EncodePageViewModel">

    <ScrollViewer Padding="32,8,32,24">
        <StackPanel Spacing="12" HorizontalAlignment="Stretch">

            <!-- ========== 标题栏 ========== -->
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Spacing="2">
                    <TextBlock Text="{DynamicResource Lang.Encode.Title}" FontSize="28" FontWeight="SemiBold"/>
                    <TextBlock Text="{DynamicResource Lang.Encode.Subtitle}" Opacity="0.7"/>
                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0" VerticalAlignment="Center">
                        <!-- 已连接：勾图标（绿色） -->
                        <TextBlock Text="✓" FontSize="16" FontWeight="Bold" Foreground="SeaGreen"
                                   VerticalAlignment="Center" IsVisible="{Binding IsEngineConnected}"/>
                        <!-- 正在连接：ProgressRing 旋转（黄色文字） -->
                        <fui:ProgressRing x:Name="EngineRing" IsActive="{Binding EngineRingActive}"
                                          Width="16" Height="16" VerticalAlignment="Center"
                                          IsVisible="{Binding IsEngineConnecting}"/>
                        <!-- 失败/未加载：叉图标（红色） -->
                        <TextBlock Text="✗" FontSize="16" FontWeight="Bold" Foreground="OrangeRed"
                                   VerticalAlignment="Center" IsVisible="{Binding IsEngineFailed}"/>
                        <TextBlock Text="{Binding EngineStatusText}"
                                   Foreground="{Binding EngineStatusForeground, FallbackValue=OrangeRed}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Top">
                    <!-- 改用普通 Button：HyperlinkButton 默认带下划线且字体发虚，
                         Button 视觉清晰，与 FluentUI 按钮风格一致 -->
                    <Button Content="{DynamicResource Lang.Encode.ResetDefaults}" Command="{Binding ResetDefaultsCommand}"/>
                    <Button Content="{DynamicResource Lang.Encode.LoadSettings}" Command="{Binding LoadSettingsCommand}"/>
                    <Button Content="{DynamicResource Lang.Encode.SaveSettings}" Command="{Binding SaveSettingsCommand}"/>
                    <Button Content="{DynamicResource Lang.Encode.SaveSettingsAs}" Command="{Binding SaveSettingsAsCommand}"/>
                </StackPanel>
            </Grid>

            <!-- ========== 输入 / 输出 + 编码设置 + 时间码设置（左右双栏）==========
                 左栏：输入/输出（含声道行表头、声道行、输出行）
                 右栏：编码设置（上）+ 时间码设置（下），垂直堆叠
                 列比例 3:2：输入区固定列多（~420px），需要更多空间 -->
            <Grid ColumnDefinitions="3*,2*" ColumnSpacing="12" HorizontalAlignment="Stretch" MinWidth="860">

                <!-- ===== 左栏：输入 / 输出 =====
                     声道输入区 MinHeight 绑定到 ViewModel.InputAreaMinHeight，
                     该值根据当前所选声道布局的声道数动态计算：
                     - 7.1 (8ch) = 表头 + 8 行高度
                     - 5.1 (6ch) = 表头 + 6 行高度
                     - 2.0 (2ch) = 表头 + 2 行高度
                     切换"单文件/分轨"模式时 MinHeight 不变（仍按当前布局计算）→ InputCard 高度稳定不收缩。
                     切换"声道布局"时 MinHeight 随之变化（用户主动选择，可接受）。 -->
                <Border Grid.Column="0" x:Name="InputCard" Classes="card" DragDrop.AllowDrop="True">
                    <StackPanel Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="24">
                            <StackPanel Grid.Column="0" Spacing="12">
                                <TextBlock Text="{DynamicResource Lang.Encode.SectionInputOutput}" FontWeight="SemiBold" FontSize="16"/>
                                <TextBlock Text="{DynamicResource Lang.T0}" Opacity="0.7" TextWrapping="Wrap"/>
                                <WrapPanel Orientation="Horizontal" ItemSpacing="12" LineSpacing="8">
                                    <RadioButton Content="{DynamicResource Lang.T1}" GroupName="inputmode" IsChecked="{Binding IsSingleFileMode, Mode=TwoWay}"/>
                                    <RadioButton Content="{DynamicResource Lang.T2}" GroupName="inputmode" IsChecked="{Binding !IsSingleFileMode}"/>
                                </WrapPanel>
                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Lang.T3}" VerticalAlignment="Center" Width="80"/>
                                    <!-- 弹性宽度：删除 MinWidth=360，让 ComboBox 占满左栏剩余空间。
                                         窄窗口时下拉框宽度自适应收缩，配合外层 ScrollViewer 兜底滚动。 -->
                                    <ComboBox HorizontalAlignment="Stretch"
                                              ItemsSource="{Binding ChannelLayoutDisplays}"
                                              SelectedItem="{Binding SelectedChannelLayoutDisplay, Mode=TwoWay}"/>
                                    <Button Content="{DynamicResource Lang.T4}" Command="{Binding ClearAllCommand}"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6" VerticalAlignment="Top">
                                <TextBlock Text="{DynamicResource Lang.T5}" FontSize="12" Opacity="0.7" HorizontalAlignment="Center"/>
                                <ctl:SpeakerLayout x:Name="SpeakerHost"/>
                            </StackPanel>
                        </Grid>

                        <!-- 单文件输入表头（与分轨表头样式一致，列宽对齐） -->
                        <Grid ColumnDefinitions="40,*,48,52,72,100,72" ColumnSpacing="6"
                              IsVisible="{Binding IsSingleFilePanelVisible}" Margin="0,4,0,4">
                            <TextBlock Grid.Column="0" Text="" Opacity="0.7" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource Lang.T6}" Opacity="0.7" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource Lang.T7}" Opacity="0.7" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{DynamicResource Lang.T8}" Opacity="0.7" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{DynamicResource Lang.T9}" Opacity="0.7" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="{DynamicResource Lang.T10}" Opacity="0.7" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="" Opacity="0.7" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- 单文件输入行：信息框（声道/位宽/采样率/时长）放在输入框右侧、浏览按钮左侧。
                             列宽与分轨行一致（40,*,48,52,72,100,72），时长列 100px 与分轨时长框完全对齐。 -->
                        <Grid ColumnDefinitions="40,*,48,52,72,100,72" ColumnSpacing="6" IsVisible="{Binding IsSingleFilePanelVisible}">
                            <!-- “输入”标签：与下方“输出”标签同列宽(40px)、同样式，左对齐一致 -->
                            <TextBlock Grid.Column="0" Text="{DynamicResource Lang.T62}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Watermark="{DynamicResource Lang.T11}" Text="{Binding SingleFilePath, Mode=TwoWay}"/>
                            <Border Grid.Column="2" CornerRadius="6" BorderThickness="1"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    Padding="6,4" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                    ToolTip.Tip="{DynamicResource Lang.T12}">
                                <TextBlock Text="{Binding SingleChannelInfo}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="3" CornerRadius="6" BorderThickness="1"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    Padding="6,4" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                    ToolTip.Tip="{DynamicResource Lang.T13}">
                                <TextBlock Text="{Binding SingleBitWidthInfo}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="4" CornerRadius="6" BorderThickness="1"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    Padding="6,4" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                    ToolTip.Tip="{DynamicResource Lang.T14}">
                                <TextBlock Text="{Binding SingleSampleRateInfo}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Border Grid.Column="5" CornerRadius="6" BorderThickness="1"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    Padding="6,4" HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                    ToolTip.Tip="{DynamicResource Lang.T15}">
                                <TextBlock Text="{Binding SingleDurationInfo}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Button Grid.Column="6" Content="{DynamicResource Lang.Common.Browse}" Command="{Binding BrowseSingleCommand}" HorizontalAlignment="Stretch"/>
                        </Grid>

                        <!-- 分轨声道输入行表头（列宽与下方 DataTemplate 行一致：32,*,48,52,72,100,72）
                             时长列加宽到 100：Duration 格式 hh:mm:ss.fff 共 12 字符，84px 不够显示。 -->
                        <Grid ColumnDefinitions="32,*,48,52,72,100,72" ColumnSpacing="6"
                              IsVisible="{Binding IsChannelRowsVisible}" Margin="0,4,0,4">
                            <TextBlock Grid.Column="0" Text="" Opacity="0.7" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{DynamicResource Lang.T6}" Opacity="0.7" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{DynamicResource Lang.T7}" Opacity="0.7" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{DynamicResource Lang.T8}" Opacity="0.7" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{DynamicResource Lang.T9}" Opacity="0.7" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="5" Text="{DynamicResource Lang.T10}" Opacity="0.7" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="6" Text="" Opacity="0.7" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- 分轨声道输入行（动态） -->
                        <ItemsControl ItemsSource="{Binding ChannelRows}" IsVisible="{Binding IsChannelRowsVisible}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="8"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ChannelRowViewModel">
                                    <Grid ColumnDefinitions="32,*,48,52,72,100,72" ColumnSpacing="6">
                                        <TextBlock Grid.Column="0" Text="{Binding Label}" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" Watermark="{DynamicResource Lang.T17}" Text="{Binding FilePath, Mode=TwoWay}"/>
                                        <!-- 声道/位宽/采样率/时长：圆角矩形框（移植自 WinUI3 ValueBox 样式）。
                                             用主题资源 ControlFillColorDefaultBrush + ControlStrokeColorDefaultBrush，
                                             浅色/深色主题自动切换。 -->
                                        <Border Grid.Column="2" CornerRadius="6" BorderThickness="1"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                Padding="6,4" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Channel}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="3" CornerRadius="6" BorderThickness="1"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                Padding="6,4" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Bw}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="4" CornerRadius="6" BorderThickness="1"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                Padding="6,4" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Fs}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Border Grid.Column="5" CornerRadius="6" BorderThickness="1"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                Padding="6,4" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Duration}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Button Grid.Column="6" Content="{DynamicResource Lang.Common.Browse}" Command="{Binding BrowseCommand}" HorizontalAlignment="Stretch"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 输出行 -->
                        <Grid ColumnDefinitions="40,*,84" ColumnSpacing="8" Margin="0,8,0,0">
                            <TextBlock Grid.Column="0" Text="{DynamicResource Lang.T18}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Watermark="D:\out\title.dtshd" Text="{Binding OutputPath, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="{DynamicResource Lang.Common.Browse}" Command="{Binding BrowseOutputCommand}" HorizontalAlignment="Stretch"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ===== 右栏：编码设置（上）+ 时间码设置（下） ===== -->
                <StackPanel Grid.Column="1" Spacing="12">

                    <!-- 右栏上：编码设置 -->
                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{DynamicResource Lang.Encode.SectionEncodeSettings}" FontWeight="SemiBold" FontSize="16"/>
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T19}" Opacity="0.7" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding DestFormats}"
                                              SelectedIndex="{Binding SelectedDestFormatIndex, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T20}" Opacity="0.7" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding StreamTypes}"
                                              SelectedIndex="{Binding SelectedStreamTypeIndex, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T21}" Opacity="0.7" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding EncodeTypeOptions}"
                                              SelectedItem="{Binding SelectedEncodeType, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T22}" Opacity="0.7" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding SampleRateOptions}"
                                              SelectedItem="{Binding SelectedSampleRate, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T8}" Opacity="0.7" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding BitWidthOptions}"
                                              SelectedItem="{Binding SelectedBitWidth, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T23}" Opacity="0.7" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding CoreBitRateOptions}"
                                              SelectedItem="{Binding CoreBitRateText, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <TextBlock Text="{DynamicResource Lang.T24}" VerticalAlignment="Center"/>
                                <ComboBox MinWidth="170"
                                          ItemsSource="{Binding DialogNormOptions}"
                                          SelectedIndex="{Binding SelectedDialogNormIndex, Mode=TwoWay}"/>
                            </StackPanel>
                            <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="6">
                                <ToggleButton Content="96/24 Core" IsChecked="{Binding Use9624, Mode=TwoWay}"/>
                                <ToggleButton Content="Rear Ch. -3dB" IsChecked="{Binding AttenuateRearCh, Mode=TwoWay}"/>
                                <ToggleButton Content="ES Phase Shift" IsChecked="{Binding EsPhaseShift, Mode=TwoWay}"/>
                                <ToggleButton Content="ES Pre-Mixed" IsChecked="{Binding IsPremixed, Mode=TwoWay}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <!-- 右栏下：时间码设置 -->
                    <Border Classes="card">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{DynamicResource Lang.Encode.SectionTimecode}" FontWeight="SemiBold" FontSize="16"/>
                            <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T25}" Opacity="0.7" FontSize="12"/>
                                    <ComboBox ItemsSource="{Binding FrameRateOptions}"
                                              SelectedItem="{Binding SelectedFrameRate, Mode=TwoWay}"
                                              HorizontalAlignment="Stretch"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T26}" Opacity="0.7" FontSize="12"/>
                                    <TextBox Text="{Binding StartTime, Mode=TwoWay}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T27}" Opacity="0.7" FontSize="12"/>
                                    <TextBox Text="{Binding EndTime, Mode=TwoWay}"/>
                                </StackPanel>
                                <CheckBox Grid.Row="1" Grid.Column="0" Content="{DynamicResource Lang.T28}"
                                          IsChecked="{Binding EncodeEntireFile, Mode=TwoWay}" VerticalAlignment="Bottom"/>
                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T29}" Opacity="0.7" FontSize="12"/>
                                    <TextBox Text="{Binding EncodeFromTime, Mode=TwoWay}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="2" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T30}" Opacity="0.7" FontSize="12"/>
                                    <TextBox Text="{Binding EncodeToTime, Mode=TwoWay}"/>
                                </StackPanel>
                                <CheckBox Grid.Row="2" Grid.Column="0" Content="{DynamicResource Lang.T31}"
                                          IsChecked="{Binding UseReferenceTime, Mode=TwoWay}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                                    <TextBlock Text="{DynamicResource Lang.T32}" Opacity="0.7" FontSize="12"/>
                                    <TextBox Text="{Binding ReferenceTime, Mode=TwoWay}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>

            <!-- ========== 比特流 (Bitstream / 元数据) ==========
                 移除外层"启用"勾选：该开关仅影响 UI 透明度，不影响 .cfg 生成。
                 按 Java GUI 行为：内层各项默认勾选状态决定是否写入 .cfg。 -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="{DynamicResource Lang.Encode.SectionBitstream}" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                </Expander.Header>
                <StackPanel Spacing="12" Margin="0,8,0,0">
                    <!-- 主音频衰减 + 单声道映射：横向滚动兜底（窄窗口溢出时用） -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <StackPanel Orientation="Horizontal" Spacing="24">
                            <!-- 主音频衰减 -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="{DynamicResource Lang.T33}" FontWeight="SemiBold"/>
                                <CheckBox Content="{DynamicResource Lang.T34}" IsChecked="{Binding UsePrimaryAudioAttenuation, Mode=TwoWay}"/>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ctl:DbFader Caption="Primary" Minimum="-60" Maximum="40" DbValue="{Binding PrimaryDb, Mode=TwoWay}"/>
                                    <StackPanel Spacing="6" VerticalAlignment="Center">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Fade Down" FontSize="12"/>
                                            <ComboBox Width="96"
                                                      ItemsSource="{Binding PaFadeOptions}"
                                                      SelectedItem="{Binding SelectedPaFadeDown, Mode=TwoWay}"/>
                                        </StackPanel>
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="Fade Up" FontSize="12"/>
                                            <ComboBox Width="96"
                                                      ItemsSource="{Binding PaFadeOptions}"
                                                      SelectedItem="{Binding SelectedPaFadeUp, Mode=TwoWay}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                            <!-- 单声道次音频声道映射 -->
                            <StackPanel Spacing="6">
                                <TextBlock Text="{DynamicResource Lang.T35}" FontWeight="SemiBold"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <ctl:DbFader Caption="L" DbValue="{Binding MonoLDb, Mode=TwoWay}"/>
                                    <ctl:DbFader Caption="R" DbValue="{Binding MonoRDb, Mode=TwoWay}"/>
                                    <ctl:DbFader Caption="C" DbValue="{Binding MonoCDb, Mode=TwoWay}"/>
                                    <ctl:DbFader Caption="Ls" DbValue="{Binding MonoLsDb, Mode=TwoWay}"/>
                                    <ctl:DbFader Caption="Rs" DbValue="{Binding MonoRsDb, Mode=TwoWay}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- AAF 元数据：所有项横排铺满，避免右侧空白 -->
                    <StackPanel Spacing="8">
                        <!-- 第 1 行：启用 AAF + 衰减方式单选（横排） -->
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <CheckBox Content="{DynamicResource Lang.T36}" IsChecked="{Binding EmbedAaf, Mode=TwoWay}" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Lang.T37}" VerticalAlignment="Center" Opacity="0.7"/>
                            <RadioButton Content="Unison" GroupName="aafatt" IsChecked="{Binding !IsAafIndependent}" VerticalAlignment="Center"/>
                            <RadioButton Content="Independent" GroupName="aafatt" IsChecked="{Binding IsAafIndependent, Mode=TwoWay}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- 第 2 行：AAF 文件路径 + 浏览（限制 TextBox MaxWidth 避免过宽） -->
                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                            <TextBlock Grid.Column="0" Text="{DynamicResource Lang.T38}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding AafFilePath, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                            <Button Grid.Column="2" Content="{DynamicResource Lang.Common.Browse}" Command="{Binding BrowseAafCommand}"/>
                        </Grid>
                        <!-- 第 3 行：7 个衰减值横排一行（Unison + 6 声道），不再竖排
                             每项 = 标签(40px) + 输入框(56px) + Spacing(10) ≈ 106px × 7 = ~740px -->
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="Unison" VerticalAlignment="Center" Width="48"/><TextBox Classes="Narrow" Width="56" Text="{Binding AafUnisonValue, Mode=TwoWay}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="LF" VerticalAlignment="Center" Width="20"/><TextBox Classes="Narrow" Width="56" Text="{Binding AafLF, Mode=TwoWay}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="RF" VerticalAlignment="Center" Width="20"/><TextBox Classes="Narrow" Width="56" Text="{Binding AafRF, Mode=TwoWay}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="C" VerticalAlignment="Center" Width="20"/><TextBox Classes="Narrow" Width="56" Text="{Binding AafC, Mode=TwoWay}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="LFE" VerticalAlignment="Center" Width="28"/><TextBox Classes="Narrow" Width="56" Text="{Binding AafLFE, Mode=TwoWay}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="LS" VerticalAlignment="Center" Width="20"/><TextBox Classes="Narrow" Width="56" Text="{Binding AafLS, Mode=TwoWay}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="RS" VerticalAlignment="Center" Width="20"/><TextBox Classes="Narrow" Width="56" Text="{Binding AafRS, Mode=TwoWay}"/></StackPanel>
                        </StackPanel>
                        <!-- 第 4 行：声像开关 + 5 个声像值横排一行 -->
                        <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="6">
                            <CheckBox Content="{DynamicResource Lang.T39}" IsChecked="{Binding AafPanningEnabled, Mode=TwoWay}" VerticalAlignment="Center"/>
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="LF" VerticalAlignment="Center" Width="20"/><TextBox Classes="Narrow" Width="56" Text="{Binding PanLF, Mode=TwoWay}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="RF" VerticalAlignment="Center" Width="20"/><TextBox Classes="Narrow" Width="56" Text="{Binding PanRF, Mode=TwoWay}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="C" VerticalAlignment="Center" Width="20"/><TextBox Classes="Narrow" Width="56" Text="{Binding PanC, Mode=TwoWay}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="LS" VerticalAlignment="Center" Width="20"/><TextBox Classes="Narrow" Width="56" Text="{Binding PanLS, Mode=TwoWay}"/></StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="4"><TextBlock Text="RS" VerticalAlignment="Center" Width="20"/><TextBox Classes="Narrow" Width="56" Text="{Binding PanRS, Mode=TwoWay}"/></StackPanel>
                        </WrapPanel>
                    </StackPanel>

                    <!-- 单一剪辑 + CSV 分支点 + CSV 文件路径：全部横排一行 -->
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox Content="{DynamicResource Lang.T40}" IsChecked="{Binding SeamlessSingleClip, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <CheckBox Content="{DynamicResource Lang.T41}" IsChecked="{Binding SeamlessCsvBranchPoints, Mode=TwoWay}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                        <TextBlock Grid.Column="0" Text="{DynamicResource Lang.T42}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding CsvFilePath, Mode=TwoWay}" HorizontalAlignment="Stretch"/>
                        <Button Grid.Column="2" Content="{DynamicResource Lang.Common.Browse}" Command="{Binding BrowseCsvCommand}"/>
                    </Grid>

                    <!-- Express + 7.1 Wide：横排一行 -->
                    <StackPanel Orientation="Horizontal" Spacing="16">
                        <CheckBox Content="{DynamicResource Lang.T43}" IsChecked="{Binding UseExpressDialogMode, Mode=TwoWay}" VerticalAlignment="Center"/>
                        <CheckBox Content="{DynamicResource Lang.T44}" IsChecked="{Binding UseWideRemapping, Mode=TwoWay}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 程序信息 -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{DynamicResource Lang.T45}" Opacity="0.7" FontSize="12"/>
                        <TextBox Watermark="{DynamicResource Lang.T46}" AcceptsReturn="True" Height="70" TextWrapping="Wrap"
                                 Text="{Binding ProgramInfo, Mode=TwoWay}"/>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- ========== 下混 (Downmix) ==========
                 移除外层"启用"勾选：该开关仅影响 UI 透明度，不影响 .cfg 生成。
                 按 Java GUI 行为：6.x/7.x 布局强制启用 5.1 下混矩阵，5.1 及以下默认关闭。 -->
            <Expander HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch">
                <Expander.Header>
                    <TextBlock Text="{DynamicResource Lang.Encode.SectionDownmix}" FontWeight="SemiBold" FontSize="16" VerticalAlignment="Center"/>
                </Expander.Header>
                <StackPanel Spacing="14" Margin="0,8,0,0">
                    <!-- 下混到 5.1 -->
                    <StackPanel Spacing="8">
                        <WrapPanel Orientation="Horizontal" ItemSpacing="16" LineSpacing="8">
                            <TextBlock Text="{DynamicResource Lang.T47}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <CheckBox Content="{DynamicResource Lang.T48}" IsChecked="{Binding Use51Downmix, Mode=TwoWay}"/>
                            <CheckBox Content="{DynamicResource Lang.T49}" IsChecked="{Binding UseCurrentChannels, Mode=TwoWay}"/>
                            <CheckBox Content="{DynamicResource Lang.T50}" IsChecked="{Binding UseLegacyMatrix, Mode=TwoWay}"/>
                        </WrapPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="0,0,0,16">
                            <StackPanel Orientation="Horizontal" Spacing="14">
                                <StackPanel Spacing="4" VerticalAlignment="Top">
                                    <TextBlock Text=" " HorizontalAlignment="Center"/>
                                    <ctl:FaderScale/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                        <ctl:DbFader Caption="L" DbValue="{Binding Dmx51LPrimary, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Lsr" DbValue="{Binding Dmx51LXchA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Rsr" DbValue="{Binding Dmx51LXchB, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <TextBlock Text="Downmix L" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                        <ctl:DbFader Caption="R" DbValue="{Binding Dmx51RPrimary, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Lsr" DbValue="{Binding Dmx51RXchA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Rsr" DbValue="{Binding Dmx51RXchB, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <TextBlock Text="Downmix R" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                        <ctl:DbFader Caption="C" DbValue="{Binding Dmx51CPrimary, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Lsr" DbValue="{Binding Dmx51CXchA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Rsr" DbValue="{Binding Dmx51CXchB, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <TextBlock Text="Downmix C" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                        <ctl:DbFader Caption="LFE" DbValue="{Binding Dmx51LfePrimary, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Lsr" DbValue="{Binding Dmx51LfeXchA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Rsr" DbValue="{Binding Dmx51LfeXchB, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <TextBlock Text="Downmix LFE" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                        <ctl:DbFader Caption="Lss" DbValue="{Binding Dmx51LsPrimary, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Lsr" DbValue="{Binding Dmx51LsXchA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Rsr" DbValue="{Binding Dmx51LsXchB, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <TextBlock Text="Downmix Ls" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Spacing="6">
                                    <StackPanel Orientation="Horizontal" Spacing="2">
                                        <ctl:DbFader Caption="Rss" DbValue="{Binding Dmx51RsPrimary, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Lsr" DbValue="{Binding Dmx51RsXchA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="Rsr" DbValue="{Binding Dmx51RsXchB, Mode=TwoWay}"/>
                                    </StackPanel>
                                    <TextBlock Text="Downmix Rs" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>

                    <!-- 下混到 2.0 -->
                    <StackPanel Spacing="8">
                        <WrapPanel Orientation="Horizontal" ItemSpacing="16" LineSpacing="8">
                            <TextBlock Text="{DynamicResource Lang.T51}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <CheckBox Content="{DynamicResource Lang.T48}" IsChecked="{Binding Use20Downmix, Mode=TwoWay}"/>
                            <RadioButton Content="Lo/Ro" GroupName="dmx20mode" IsChecked="{Binding !Is2ChDmixLtRt}"/>
                            <RadioButton Content="Lt/Rt" GroupName="dmx20mode" IsChecked="{Binding Is2ChDmixLtRt, Mode=TwoWay}"/>
                            <CheckBox Content="{DynamicResource Lang.T52}" IsChecked="{Binding DownmixSaturationCheck, Mode=TwoWay}"/>
                            <CheckBox Content="{DynamicResource Lang.T53}" IsChecked="{Binding IsEmbeddedDownmix, Mode=TwoWay}"/>
                        </WrapPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Padding="0,0,0,16">
                            <StackPanel Orientation="Horizontal" Spacing="18">
                                <StackPanel Spacing="4" VerticalAlignment="Top">
                                    <TextBlock Text=" " HorizontalAlignment="Center"/>
                                    <ctl:FaderScale/>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="L In" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <ctl:DbFader Caption="a" DbValue="{Binding Dmx20LeftA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="b" DbValue="{Binding Dmx20LeftB, Mode=TwoWay}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="R In" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <ctl:DbFader Caption="a" DbValue="{Binding Dmx20RightA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="b" DbValue="{Binding Dmx20RightB, Mode=TwoWay}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="C In" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <ctl:DbFader Caption="a" DbValue="{Binding Dmx20CenterA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="b" DbValue="{Binding Dmx20CenterB, Mode=TwoWay}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="LFE In" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <ctl:DbFader Caption="a" DbValue="{Binding Dmx20LfeA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="b" DbValue="{Binding Dmx20LfeB, Mode=TwoWay}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Ls In" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <ctl:DbFader Caption="a" DbValue="{Binding Dmx20LsA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="b" DbValue="{Binding Dmx20LsB, Mode=TwoWay}"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Rs In" HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <ctl:DbFader Caption="a" DbValue="{Binding Dmx20RsA, Mode=TwoWay}"/>
                                        <ctl:DbFader Caption="b" DbValue="{Binding Dmx20RsB, Mode=TwoWay}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>
                </StackPanel>
            </Expander>

            <!-- ========== 操作 + 进度 ==========
                 预览 .cfg / 预览命令 / 查看日志 改为弹窗形式（TextPreviewWindow）。
                 内联预览 TextBox 与日志 Expander 已移除，改为按钮点击弹出独立窗口。 -->
            <Border Classes="card">
                <StackPanel Spacing="10">
                    <!-- 操作按钮行：开始编码(蓝) + 终止编码(红) + 打开编码队列；
                         右侧预览按钮组 + 查看日志。
                         WrapPanel：窄窗口下按钮自动换行，避免挤压重叠。 -->
                    <WrapPanel Orientation="Horizontal" ItemSpacing="10" LineSpacing="8">
                        <!-- 开始编码：蓝色背景（固定蓝色，hover/pressed 不丢失背景色，仅做亮度反馈） -->
                        <Button Content="{DynamicResource Lang.Encode.Start}" Classes="encode-start" Command="{Binding EncodeCommand}"/>
                        <!-- 终止编码：红色背景（固定红色，hover/pressed 不丢失背景色，仅做亮度反馈） -->
                        <Button Content="{DynamicResource Lang.Encode.Stop}" Classes="encode-stop" Command="{Binding AbortCommand}"/>
                        <!-- 打开编码队列弹窗 -->
                        <Button Content="{DynamicResource Lang.Encode.OpenQueue}" Click="OnOpenQueueClick"/>
                        <!-- 预览按钮组：左侧加 margin 视觉分隔，点击触发 TextPreviewWindow 弹窗 -->
                        <Button Content="{DynamicResource Lang.Encode.PreviewCfg}" Click="OnPreviewCfgClick" Margin="16,0,0,0"/>
                        <Button Content="{DynamicResource Lang.Encode.PreviewCmd}" Click="OnPreviewCommandClick"/>
                        <!-- 查看日志：点击触发弹窗，避免占用主界面空间 -->
                        <Button Content="{DynamicResource Lang.Encode.ViewLog}" Click="OnShowLogClick"/>
                    </WrapPanel>

                    <!-- 总进度条 -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="{Binding ProgressText}" FontSize="12" Opacity="0.8"/>
                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding OverallProgress}" Height="6"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>

    <!-- 按钮样式：固定背景色，hover/pressed 不丢失背景色，仅做亮度反馈。
         关键：FluentButton 模板在 :pointerover/:pressed 时会用
         /template/ ContentPresenter#PART_ContentPresenter 选择器把 Background
         覆盖成 ControlFillColorSecondary/Tertiary（半透明灰），所以仅设置
         Button.Background 无效——必须用同样的 /template/ 选择器覆盖回我们的颜色。 -->
    <UserControl.Styles>
        <!-- ====== 统一 TextBox 高度：紧凑 Padding，避免输入框过高 ====== -->
        <Style Selector="TextBox">
            <Setter Property="Padding" Value="8,4"/>
        </Style>
        <!-- AAF/CSV 那种窄 TextBox（Width=60）需要更紧凑 -->
        <Style Selector="TextBox.Narrow">
            <Setter Property="Padding" Value="6,4"/>
        </Style>

        <!-- ====== 统一 Button 尺寸：固定高度 + 紧凑 Padding，所有按钮视觉一致 ======
             FluentButton 默认 Padding=20,4,20,4（左右太宽），Height 不固定。
             改为 Padding=12,4 + MinHeight=30，所有按钮高度一致，宽度按内容自适应。 -->
        <Style Selector="Button">
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 开始编码：蓝色（与系统主题蓝一致，固定不丢失） -->
        <Style Selector="Button.encode-start">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BackgroundSizing" Value="OuterBorderEdge"/>
            <!-- 默认（无伪类）：模板内 ContentPresenter 也用蓝色 -->
            <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#0078D4"/>
                <Setter Property="BorderBrush" Value="#0078D4"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Transitions">
                    <Transitions>
                        <BrushTransition Property="Background" Duration="00:00:00.083"/>
                    </Transitions>
                </Setter>
            </Style>
        </Style>
        <!-- hover：略微提亮（保持蓝色，不透明化） -->
        <Style Selector="Button.encode-start:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#1A86DA"/>
            <Setter Property="BorderBrush" Value="#1A86DA"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- pressed：略微压暗（按下反馈，仍保持蓝色） -->
        <Style Selector="Button.encode-start:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#0064B0"/>
            <Setter Property="BorderBrush" Value="#0064B0"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <!-- 终止编码：红色（固定不丢失） -->
        <Style Selector="Button.encode-stop">
            <Setter Property="Background" Value="#E53935"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#E53935"/>
            <Setter Property="BackgroundSizing" Value="OuterBorderEdge"/>
            <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="#E53935"/>
                <Setter Property="BorderBrush" Value="#E53935"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Transitions">
                    <Transitions>
                        <BrushTransition Property="Background" Duration="00:00:00.083"/>
                    </Transitions>
                </Setter>
            </Style>
        </Style>
        <!-- hover：略微提亮（保持红色） -->
        <Style Selector="Button.encode-stop:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#EF4A46"/>
            <Setter Property="BorderBrush" Value="#EF4A46"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <!-- pressed：略微压暗（按下反馈，仍保持红色） -->
        <Style Selector="Button.encode-stop:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="#C02E2A"/>
            <Setter Property="BorderBrush" Value="#C02E2A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Styles>
</UserControl>
