<UserControl
    x:Class="DTSHD.Encoder.Avalonia.Views.SettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:DTSHD.Encoder.Avalonia.ViewModels"
    mc:Ignorable="d"
    x:DataType="vm:SettingsPageViewModel">

    <UserControl.Styles>
        <!-- 超链接样式按钮：透明背景 + 强调色文字 + hover 下划线 + 手型光标。
             FluentButton 模板在 :pointerover/:pressed 会用 /template/ ContentPresenter
             覆盖背景，故需用相同选择器把背景压回 Transparent（参考 EncodeView 按钮样式做法）。 -->
        <Style Selector="Button.link">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.link /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
        </Style>
        <Style Selector="Button.link:pointerover /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorSecondaryBrush}"/>
            <Setter Property="TextBlock.TextDecorations" Value="Underline"/>
        </Style>
        <Style Selector="Button.link:pressed /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextFillColorTertiaryBrush}"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer Padding="32,8,32,24">
        <StackPanel Spacing="16" HorizontalAlignment="Stretch">

            <!-- 标题 -->
            <StackPanel Spacing="2">
                <TextBlock Text="{DynamicResource Lang.Settings.Title}" FontSize="28" FontWeight="SemiBold"/>
                <TextBlock Text="{DynamicResource Lang.Settings.Subtitle}" Opacity="0.7"/>
            </StackPanel>

            <!-- ========== 引擎 ========== -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="{DynamicResource Lang.Settings.Engine}" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Text="{DynamicResource Lang.Settings.EngineDesc}" Opacity="0.7"/>

                    <!-- 工具集目录行 -->
                    <Grid ColumnDefinitions="120,*,Auto" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="{DynamicResource Lang.Settings.ToolDir}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" Text="{Binding ToolDir, Mode=TwoWay}"/>
                        <Button Grid.Column="2" Content="{DynamicResource Lang.Common.Browse}" Command="{Binding BrowseToolDirCommand}"/>
                    </Grid>

                    <!-- 状态行 -->
                    <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                        <Grid Grid.Column="0" VerticalAlignment="Center">
                            <Ellipse Width="12" Height="12" Fill="SeaGreen" IsVisible="{Binding ToolsetReady}"/>
                            <Ellipse Width="12" Height="12" Fill="OrangeRed" IsVisible="{Binding !ToolsetReady}"/>
                        </Grid>
                        <TextBlock Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center"
                                   Text="{Binding StatusText}"/>
                        <Button Grid.Column="2" Content="{DynamicResource Lang.Settings.AutoDetect}" Margin="0,0,8,0"
                                Command="{Binding DetectCommand}"/>
                        <Button Grid.Column="3" Content="{DynamicResource Lang.Settings.OpenDir}" Command="{Binding OpenDirCommand}"/>
                    </Grid>

                    <!-- 工具存在性清单 -->
                    <ItemsControl ItemsSource="{Binding ToolItems}" Margin="20,0,0,0">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Spacing="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ToolStatusItem">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="✓" FontSize="14" Foreground="SeaGreen"
                                               VerticalAlignment="Center" IsVisible="{Binding Ok}"/>
                                    <TextBlock Text="✗" FontSize="14" Foreground="OrangeRed"
                                               VerticalAlignment="Center" IsVisible="{Binding !Ok}"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Button Content="{DynamicResource Lang.Settings.SaveReconnect}" Classes="accent" Command="{Binding SaveReconnectCommand}"/>
                </StackPanel>
            </Border>

            <!-- ========== 外观 ========== -->
            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="{DynamicResource Lang.Settings.Appearance}" FontWeight="SemiBold" FontSize="16"/>
                    <StackPanel Orientation="Horizontal" Spacing="32">
                        <StackPanel Spacing="4">
                            <TextBlock Text="{DynamicResource Lang.Settings.Mica}"/>
                            <ToggleSwitch OnContent="{DynamicResource Lang.Settings.On}" OffContent="{DynamicResource Lang.Settings.Off}"
                                          IsChecked="{Binding MicaEnabled, Mode=TwoWay}"/>
                        </StackPanel>
                        <StackPanel Spacing="4">
                            <TextBlock Text="{DynamicResource Lang.Settings.Theme}"/>
                            <ComboBox Width="160"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedIndex="{Binding SelectedThemeIndex, Mode=TwoWay}"/>
                        </StackPanel>
                        <!-- 语言：实时切换简体中文 / 英文 -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="{DynamicResource Lang.Settings.Language}"/>
                            <ComboBox Width="160"
                                      ItemsSource="{Binding LanguageOptions}"
                                      SelectedIndex="{Binding SelectedLanguageIndex, Mode=TwoWay}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== 关于 ========== -->
            <Border Classes="card">
                <StackPanel Spacing="4">
                    <TextBlock Text="{DynamicResource Lang.Settings.About}" FontWeight="SemiBold" FontSize="16"/>
                    <TextBlock Text="DTS-HD Master Audio Suite Encoder" FontWeight="SemiBold"/>
                    <!-- 版本号绑定 AppVersion（与 csproj Version 一致，语言中立文案） -->
                    <TextBlock Text="{Binding AppVersion, StringFormat='v{0} · Avalonia · DtsJobQueue'}" Opacity="0.8"/>
                    <TextBlock Text="作者 / Authors：cgyihai / linmeng" FontWeight="SemiBold" Margin="0,4,0,0"/>
                    <!-- 项目主页链接：点击用系统默认浏览器打开 GitHub（查看更新与新构建版本） -->
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,4,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource Lang.Settings.Homepage}" Opacity="0.8" VerticalAlignment="Center"/>
                        <Button Classes="link" Command="{Binding OpenGitHubCommand}"
                                Content="{Binding GitHubUrl}"
                                ToolTip.Tip="GitHub"/>
                    </StackPanel>

                    <!-- 在线更新：点击"检查更新"查询 GitHub 最新 Release；发现新版时出现"前往下载"。 -->
                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,8,0,0" VerticalAlignment="Center">
                        <Button Content="{DynamicResource Lang.Settings.CheckUpdate}" Command="{Binding CheckUpdateCommand}"/>
                        <Button Classes="link" Content="{DynamicResource Lang.Settings.OpenDownload}" Command="{Binding OpenDownloadCommand}"
                                IsVisible="{Binding UpdateAvailable}"/>
                        <TextBlock Text="{Binding UpdateStatus}" Opacity="0.8" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                    <!-- 启动时自动检查更新开关 -->
                    <CheckBox Content="{DynamicResource Lang.Settings.AutoCheckUpdate}" Margin="0,4,0,0"
                              IsChecked="{Binding AutoCheckUpdate, Mode=TwoWay}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
