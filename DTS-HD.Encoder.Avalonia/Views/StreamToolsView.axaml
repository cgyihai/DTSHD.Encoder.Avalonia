<UserControl
    x:Class="DTSHD.Encoder.Avalonia.Views.StreamToolsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fui="using:AvaloniaFluentUI.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:DTSHD.Encoder.Avalonia.ViewModels"
    mc:Ignorable="d"
    x:DataType="vm:StreamToolsPageViewModel">

    <!--
        DTS-HD StreamTools 页：从 WinUI3 StreamToolsPage.xaml 完整移植。
        WinUI3 <Pivot> + <PivotItem> → Avalonia <TabControl> + <TabItem>（11 个标签页）。
        WinUI3 <Border Style="{StaticResource Card}"> → <Border Classes="card">（CardStyle.axaml 已全局合并）。
        PBR 图表：<Canvas x:Name="PbrCanvas"> 在 code-behind 按 VM.PbrPoints 绘制（移植自 WinUI3 DrawPbrGraph）。
    -->
    <!-- 根 ScrollViewer：窄高度窗口下保证 11 个标签页内容可垂直滚动到底部按钮。
         原根 Grid 的 Margin=32,8,32,16 移到 ScrollViewer.Padding，行为等价。 -->
    <ScrollViewer Padding="32,8,32,16" HorizontalScrollBarVisibility="Disabled">
    <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">

        <!-- ========== 标题栏 ========== -->
        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="DTS-HD StreamTools" FontSize="28" FontWeight="SemiBold"/>
            <TextBlock Text="对已编码的 .dtshd/.cpt 码流做信息/校验/拆分/合并/裁剪/加静音/重打时间码/元数据等处理（原生 DTSToolFramewrk 引擎，模块 T）。" Opacity="0.7" TextWrapping="Wrap"/>
            <!-- 引擎状态：三态图标（✓ 绿 / ProgressRing 黄 / ✗ 红）+ 文字 -->
            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0" VerticalAlignment="Center">
                <!-- 已连接：勾图标（绿色） -->
                <TextBlock Text="✓" FontSize="16" FontWeight="Bold" Foreground="SeaGreen"
                           VerticalAlignment="Center" IsVisible="{Binding IsEngineConnected}"/>
                <!-- 正在连接：ProgressRing 旋转（黄色文字） -->
                <fui:ProgressRing IsActive="{Binding EngineRingActive}"
                                  Width="16" Height="16" VerticalAlignment="Center"
                                  IsVisible="{Binding IsEngineConnecting}"/>
                <!-- 失败/未加载：叉图标（红色） -->
                <TextBlock Text="✗" FontSize="16" FontWeight="Bold" Foreground="OrangeRed"
                           VerticalAlignment="Center" IsVisible="{Binding IsEngineFailed}"/>
                <TextBlock Text="{Binding EngineStatusText}"
                           Foreground="{Binding EngineStatusForeground, FallbackValue=OrangeRed}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>

        <!-- ========== 11 个标签页（WinUI3 Pivot） ========== -->
        <TabControl Grid.Row="1" Padding="0">

            <!-- 1. 信息 -->
            <TabItem Header="信息">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="读取码流信息 (InfoDumper / T I)" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBox Grid.Column="0" PlaceholderText="选择 .dtshd / .cpt" Text="{Binding InfoFile, Mode=TwoWay}"/>
                            <Button Grid.Column="1" Content="浏览…" Command="{Binding BrowseCommand}" CommandParameter="InfoFile" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="读取信息" Classes="accent" Command="{Binding InfoCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 2. 校验 -->
            <TabItem Header="校验">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="校验码流 (DTSHDVerify.exe)" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBox Grid.Column="0" PlaceholderText="选择 .dtshd / .cpt" Text="{Binding VerifyFile, Mode=TwoWay}"/>
                            <Button Grid.Column="1" Content="浏览…" Command="{Binding BrowseCommand}" CommandParameter="VerifyFile" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="校验" Classes="accent" Command="{Binding VerifyCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 3. 拆分 -->
            <TabItem Header="拆分">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="按时间码拆分为两个文件 (T S)" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="输入" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" PlaceholderText=".dtshd" Text="{Binding SplitIn, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseCommand}" CommandParameter="SplitIn"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,160" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="拆分时间码" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SplitTc, Mode=TwoWay}"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="输出 1" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" PlaceholderText="part1.dtshd" Text="{Binding SplitOut1, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseSaveCommand}" CommandParameter="SplitOut1"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="输出 2" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" PlaceholderText="part2.dtshd" Text="{Binding SplitOut2, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseSaveCommand}" CommandParameter="SplitOut2"/>
                        </Grid>
                        <Button Content="拆分" Classes="accent" Command="{Binding SplitCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 4. 合并 -->
            <TabItem Header="合并">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="合并两个码流 (T J)" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="文件 1" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding JoinF1, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseCommand}" CommandParameter="JoinF1"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="文件 2" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding JoinF2, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseCommand}" CommandParameter="JoinF2"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="输出" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" PlaceholderText="joined.dtshd" Text="{Binding JoinOut, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseSaveCommand}" CommandParameter="JoinOut"/>
                        </Grid>
                        <Button Content="合并" Classes="accent" Command="{Binding JoinCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 5. 裁剪 -->
            <TabItem Header="裁剪">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="按起止时间码裁剪 (T T)" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="输入" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding TrimIn, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseCommand}" CommandParameter="TrimIn"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,150,Auto,150" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="开始" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding TrimStart, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2" Text="结束" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="3" Text="{Binding TrimEnd, Mode=TwoWay}"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="输出" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" PlaceholderText="trimmed.dtshd" Text="{Binding TrimOut, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseSaveCommand}" CommandParameter="TrimOut"/>
                        </Grid>
                        <Button Content="裁剪" Classes="accent" Command="{Binding TrimCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 6. 加静音 -->
            <TabItem Header="加静音">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="在头/尾添加静音并重设起始时间码 (T N)" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="输入" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SilIn, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseCommand}" CommandParameter="SilIn"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,150,Auto,150" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="头部静音" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SilHead, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2" Text="尾部静音" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="3" Text="{Binding SilTail, Mode=TwoWay}"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,150" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="新起始TC" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding SilNewTc, Mode=TwoWay}"/>
                        </Grid>
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="输出" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" PlaceholderText="with_silence.dtshd" Text="{Binding SilOut, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseSaveCommand}" CommandParameter="SilOut"/>
                        </Grid>
                        <Button Content="加静音" Classes="accent" Command="{Binding AddSilenceCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 7. 重打时间码 -->
            <TabItem Header="重打时间码">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="按新帧率/起始时间码重打 (T R)" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="文件" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding ReFile, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseCommand}" CommandParameter="ReFile"/>
                        </Grid>
                        <Grid ColumnDefinitions="90,150,Auto,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="新起始TC" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding ReStart, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2" Text="新帧率" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="3" Width="130"
                                      ItemsSource="{Binding FrameRateOptions}"
                                      SelectedIndex="{Binding SelectedReFpsIndex, Mode=TwoWay}"/>
                        </Grid>
                        <Button Content="重打时间码" Classes="accent" Command="{Binding RestripeCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 8. 元数据 -->
            <TabItem Header="元数据">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="修改对话归一化 / 帧率 / 起始时间码 (T M)" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="90,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="文件" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding MetaFile, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseCommand}" CommandParameter="MetaFile"/>
                        </Grid>
                        <Grid ColumnDefinitions="90,150,Auto,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="新起始TC" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding MetaStart, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2" Text="新帧率" VerticalAlignment="Center"/>
                            <ComboBox Grid.Column="3" Width="130"
                                      ItemsSource="{Binding FrameRateOptions}"
                                      SelectedIndex="{Binding SelectedMetaFpsIndex, Mode=TwoWay}"/>
                        </Grid>
                        <Grid ColumnDefinitions="90,150,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="对话归一化" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" Text="{Binding MetaDialNorm, Mode=TwoWay}"/>
                            <TextBlock Grid.Column="2" Text="dBFS" VerticalAlignment="Center" Opacity="0.6"/>
                        </Grid>
                        <Button Content="写入元数据" Classes="accent" Command="{Binding MetadataCommand}" HorizontalAlignment="Left"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 9. 追加合并（多文件行 ItemsControl，行模板绑定 AppendRowViewModel） -->
            <TabItem Header="追加合并">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="将多个文件按各自起止时间码顺序追加合并 (T A)" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">
                            <TextBlock Grid.Column="0" Text="输出" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1" PlaceholderText="appended.dtshd" Text="{Binding AppendOut, Mode=TwoWay}"/>
                            <Button Grid.Column="2" Content="浏览…" Command="{Binding BrowseSaveCommand}" CommandParameter="AppendOut"/>
                        </Grid>
                        <TextBlock Text="输入文件（按合并顺序，含各自起止时间码）" Opacity="0.7"/>
                        <ItemsControl ItemsSource="{Binding AppendRows}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="8"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:AppendRowViewModel">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                                        <TextBox Grid.Column="0" PlaceholderText=".dtshd" Text="{Binding FilePath, Mode=TwoWay}"/>
                                        <Button Grid.Column="1" Content="浏览…" Command="{Binding BrowseCommand}"/>
                                        <TextBox Grid.Column="2" Width="120" Text="{Binding Start, Mode=TwoWay}"/>
                                        <TextBox Grid.Column="3" Width="120" Text="{Binding End, Mode=TwoWay}"/>
                                        <Button Grid.Column="4" Content="✕" Command="{Binding RemoveCommand}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="＋ 添加文件行" Command="{Binding AddAppendRowCommand}"/>
                            <Button Content="追加合并" Classes="accent" Command="{Binding AppendCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 10. PBR 分析（Canvas 在 code-behind 按 PbrPoints 绘制折线图） -->
            <TabItem Header="PBR 分析">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="峰值比特率分析：生成 .dtspbr 并绘制曲线 (T P)" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                            <TextBox Grid.Column="0" PlaceholderText="选择 .dtshd" Text="{Binding PbrFile, Mode=TwoWay}"/>
                            <Button Grid.Column="1" Content="浏览…" Command="{Binding BrowseCommand}" CommandParameter="PbrFile" Margin="0,0,8,0"/>
                            <Button Grid.Column="2" Content="分析" Classes="accent" Command="{Binding PbrCommand}"/>
                        </Grid>
                        <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="6"
                                Height="280" Background="{DynamicResource LayerFillBrush}">
                            <Canvas x:Name="PbrCanvas" Background="Transparent" SizeChanged="OnPbrCanvasSizeChanged"/>
                        </Border>
                        <TextBlock Opacity="0.7" Text="Peak Bit Rate Schedule — 时间码 vs kbps"/>
                    </StackPanel>
                </Border>
            </TabItem>

            <!-- 11. 原始命令 -->
            <TabItem Header="原始命令">
                <Border Classes="card">
                    <StackPanel Spacing="10">
                        <TextBlock Text="高级：直接发送 T 命令（用于尚未做成界面的操作）" FontWeight="SemiBold"/>
                        <TextBox PlaceholderText='例如: T I "D:\out\title.dtshd"' Text="{Binding RawCmd, Mode=TwoWay}"/>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Button Content="发送" Command="{Binding RawSendCommand}"/>
                            <Button Content="取消操作 (T Z)" Command="{Binding CancelOpCommand}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </TabItem>

        </TabControl>

        <!-- ========== 工具响应 / 日志 ========== -->
        <Border Grid.Row="2" Classes="card" Padding="16">
            <StackPanel Spacing="4">
                <Grid>
                    <TextBlock Text="工具响应 / 日志" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding OpStatus}" Opacity="0.75" HorizontalAlignment="Right"/>
                </Grid>
                <ProgressBar Minimum="0" Maximum="100"
                             IsVisible="{Binding IsOpProgressVisible}"
                             IsIndeterminate="{Binding IsOpProgressIndeterminate}"
                             Value="{Binding OpProgressValue}"/>
                <TextBox Height="180" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas"
                         Text="{Binding LogText, Mode=OneWay}"/>
            </StackPanel>
        </Border>

    </Grid>
    </ScrollViewer>
</UserControl>
